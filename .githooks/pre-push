#!/bin/bash
# .githooks/pre-push

echo "============================================================"
echo "🚀 运行预推送检查 (Pre-Push Hook): 集成测试"
echo "============================================================"

# 获取当前操作系统
OS="`uname`"
PYTHON_CMD="python"

case $OS in
  'Linux'|'Darwin')
    PYTHON_CMD="python3"
    ;;
esac

# 检查是否有 python 别名，如果没有则尝试 python3
if ! command -v $PYTHON_CMD &> /dev/null
then
    PYTHON_CMD="python3"
fi

# 运行集成测试 (重点路径)
$PYTHON_CMD -m pytest backend/tests/integration/ -v -s

# 捕获测试的退出码
TEST_EXIT_CODE=$?

if [ $TEST_EXIT_CODE -ne 0 ]; then
  echo "============================================================"
  echo "❌ 集成测试失败！推送已被拦截。"
  echo "请修复代码后再次提交推送。如果必须跳过验证（如紧急修复），请使用 git push --no-verify"
  echo "============================================================"
  exit 1
fi

echo "============================================================"
echo "✅ 集成测试全部通过，允许推送！"
echo "============================================================"
exit 0
